{
  "name": "boardsesh-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter=@boardsesh/shared-schema build && bun run --filter=@boardsesh/crypto build && bun run --filter=@boardsesh/db build && bun run --filter='*' build",
    "build:web": "bun run --filter=@boardsesh/web build",
    "build:backend": "bun run --filter=boardsesh-backend build",
    "build:shared": "bun run --filter=@boardsesh/shared-schema build",
    "build:crypto": "bun run --filter=@boardsesh/crypto build",
    "build:db": "bun run --filter=@boardsesh/db build",
    "lint": "vp lint",
    "typecheck": "bun run --filter='*' typecheck",
    "typecheck:web": "bun run --filter=@boardsesh/web typecheck",
    "typecheck:backend": "bun run --filter=boardsesh-backend typecheck",
    "typecheck:db": "bun run --filter=@boardsesh/db typecheck",
    "typecheck:shared": "bun run --filter=@boardsesh/shared-schema typecheck",
    "test": "vp test",
    "test:run": "vp test run",
    "check": "vp check",
    "format": "vp fmt",
    "test:e2e:setup": "vp run db:up",
    "test:e2e": "bun run test:e2e:setup && TEST_USER_EMAIL=test@boardsesh.com TEST_USER_PASSWORD=test bun run --filter=@boardsesh/web test:e2e",
    "test:help-screenshots": "TEST_USER_EMAIL=$(op read 'op://Boardsesh/Boardsesh local/username') TEST_USER_PASSWORD=$(op read 'op://Boardsesh/Boardsesh local/password') bunx playwright test --project=help-screenshots --config=packages/web/playwright.config.ts",
    "test:app-store-screenshots": "TEST_USER_EMAIL=$(op read 'op://Boardsesh/Boardsesh local/username') TEST_USER_PASSWORD=$(op read 'op://Boardsesh/Boardsesh local/password') bunx playwright test --project=app-store-screenshots --config=packages/web/playwright.config.ts",
    "backend:dev": "bun run --filter=boardsesh-backend dev",
    "backend:start": "bun run --filter=boardsesh-backend start",
    "db:migrate": "bun run --filter=@boardsesh/db db:migrate",
    "db:studio": "bun run --filter=@boardsesh/db db:studio",
    "db:import-moonboard": "bun run --filter=@boardsesh/db db:import-moonboard",
    "db:seed-social": "bun run --filter=@boardsesh/db db:seed-social",
    "db:create-test-user": "bun run --filter=@boardsesh/db db:create-test-user",
    "db:seed-locations": "bun run --filter=@boardsesh/db db:seed-locations",
    "controller:codegen": "node embedded/scripts/generate-graphql-types.mjs",
    "controller:codegen:board-data": "node embedded/scripts/generate-board-data.mjs",
    "controller:codegen:test": "node --test embedded/scripts/generate-graphql-types.test.mjs && node --test embedded/scripts/generate-board-data.test.mjs && python3 embedded/scripts/test_prebuild.py",
    "controller:build": "cd embedded/projects/board-controller && pio run",
    "controller:upload": "cd embedded/projects/board-controller && pio run -t upload",
    "controller:monitor": "cd embedded/projects/board-controller && pio device monitor",
    "moonboard:build": "cd embedded/projects/moonboard-dev-server && pio run",
    "moonboard:upload": "cd embedded/projects/moonboard-dev-server && pio run -t upload",
    "moonboard:monitor": "cd embedded/projects/moonboard-dev-server && pio device monitor",
    "controller:format": "find embedded -name '*.cpp' -o -name '*.h' | xargs clang-format -i",
    "controller:format:check": "find embedded -name '*.cpp' -o -name '*.h' | xargs clang-format --dry-run --Werror",
    "build:wasm": "cd packages/board-renderer-wasm && bash build.sh"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.4",
    "oxlint-tsgolint": "^0.21.1",
    "vite-plus": "^0.1.18",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": "22.x"
  },
  "packageManager": "bun@1.3.13"
}